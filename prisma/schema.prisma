generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Prompt {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String   @default("general")
  version   Int      @default(1)
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QueryRecord {
  id           String   @id @default(cuid())
  query        String
  models       String   // JSON string of model IDs
  results      String   // JSON string of model results
  synthesis    String?  // JSON string of synthesis result
  workflowType String?  // optional workflow type
  createdAt    DateTime @default(now())
}

model WorkflowTemplate {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String
  systemPrompt String
  steps       String   // JSON string of steps
  icon        String   @default("FileText")
  createdAt   DateTime @default(now())
}
